---
import { getLocaleFromUrl, getLocalePath } from '../i18n/utils';

const currentLocale = getLocaleFromUrl(Astro.url);

const enPath = getLocalePath('en');
const esPath = getLocalePath('es');
---

<div class="flex items-center gap-2 text-lg font-medium">
  {currentLocale === 'en' ? (
    <span class="text-teal-400">EN</span>
  ) : (
    <a href={enPath} data-lang-switch class="text-slate-300 hover:text-teal-400 transition-colors duration-200">EN</a>
  )}
  <span class="text-slate-500">|</span>
  {currentLocale === 'es' ? (
    <span class="text-teal-400">ES</span>
  ) : (
    <a href={esPath} data-lang-switch class="text-slate-300 hover:text-teal-400 transition-colors duration-200">ES</a>
  )}
</div>

<script>
  // Preserve hash fragment when switching languages
  document.querySelectorAll('[data-lang-switch]').forEach(link => {
    link.addEventListener('click', (e) => {
      if (window.location.hash) {
        e.preventDefault();
        const href = (e.currentTarget as HTMLAnchorElement).href;
        window.location.href = href + window.location.hash;
      }
    });
  });
</script>
