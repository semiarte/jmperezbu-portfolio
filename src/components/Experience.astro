---
import { getCollection } from "astro:content";
import ExternalLink from "./icons/ExternalLink.astro";
import ScrollReveal from "./ScrollReveal.astro";

const experienceData = await getCollection("experience");
const experiences = experienceData[0].data.experience;
---

<section id="experience" aria-label="Work experience section" class="py-20 px-8">
  <ScrollReveal>
    <h2 class="text-4xl font-semibold mb-12">Experience</h2>
  </ScrollReveal>
  <div class="space-y-8">
    {experiences.map((exp, index) => (
      <ScrollReveal delay={index * 100}>
        <a href={exp.url} target="_blank" rel="noopener noreferrer" class="block">
          <div class="rounded-md p-6 md:p-8 border border-slate-700 hover:bg-(--navy) hover:border-teal-400 transition-all duration-200 transform hover:-translate-y-1">
            <div class="flex flex-col md:flex-row md:justify-between md:items-start gap-6 md:gap-12">
              <div class="flex-1">
                <div class="flex items-center gap-3 mb-2">
                  <h3 class="text-slate-200 text-2xl font-semibold">{exp.company}</h3>
                  <ExternalLink class="text-slate-200" />
                </div>
                <p class="text-base md:text-lg text-slate-400">{exp.activity}</p>
              </div>
              <div class="flex-1">
                <div class="flex flex-wrap items-start justify-between gap-3 mb-3.5">
                  <p class="font-medium text-lg text-slate-300">{exp.position}</p>
                  <span class="px-4 py-2 rounded-full bg-teal-900/20 text-teal-400 text-xs font-medium whitespace-nowrap" aria-label={`Employment period: ${exp.period}`}>{exp.period}</span>
                </div>
                <p class="text-base md:text-lg text-slate-300">{exp.description}</p>
              </div>
            </div>
          </div>
        </a>
      </ScrollReveal>
    ))}
  </div>
</section>
