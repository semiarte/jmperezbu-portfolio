---
import Github from "./icons/Github.astro";
import Linkedin from "./icons/Linkedin.astro";

interface Props {
  githubUrl: string;
  linkedinUrl: string;
}

const { githubUrl, linkedinUrl } = Astro.props;
---

<div class="flex gap-6">
  <a href={linkedinUrl} target="_blank" rel="noopener noreferrer" class="flex flex-col items-center" aria-label="LinkedIn profile">
    <div class="mb-4 p-3 border border-gray-700 rounded-full text-gray-400 hover:border-teal-700 hover:text-teal-400 hover:-translate-y-1 transition-all duration-200">
      <Linkedin size={24} />
    </div>
  </a>
  <a href={githubUrl} target="_blank" rel="noopener noreferrer" class="flex flex-col items-center" aria-label="GitHub profile">
    <div class="mb-4 p-3 border border-gray-700 rounded-full text-gray-400 hover:border-teal-700 hover:text-teal-400 hover:-translate-y-1 transition-all duration-200">
      <Github size={24} />
    </div>
  </a>
</div>
