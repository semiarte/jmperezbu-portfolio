---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import Experience from '../components/Experience.astro';
import ProjectsSection from '../components/ProjectsSection.astro';
import Contact from '../components/Contact.astro';
import Footer from '../components/Footer.astro';
import PersonJsonLd from '../components/PersonJsonLd.astro';
import { getLocaleFromUrl, getTranslations } from '../i18n/utils';

const locale = getLocaleFromUrl(Astro.url);
const t = getTranslations(locale);
---

<BaseLayout title={t.meta.title} description={t.meta.description} locale={locale}>
  <PersonJsonLd locale={locale} />
  <div class="min-h-screen flex flex-col bg-linear-180 from-(--navy) to bg-(--dark-navy) text-slate-200 scroll-smooth">
    <Header locale={locale} />
    <main class="flex-1 max-w-7xl mx-auto">
      <Hero locale={locale} />
      <Experience locale={locale} />
      <ProjectsSection locale={locale} />
      <Contact locale={locale} />
    </main>
    <Footer locale={locale} />
  </div>
</BaseLayout>
