---
import { getLocalizedProjects } from '../../../i18n/content';
import type { Locale } from '../../../i18n/types';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import ProjectDetail from '../../../components/ProjectDetail.astro';
import { getTranslations } from '../../../i18n/utils';

export async function getStaticPaths() {
  const locale: Locale = 'es';
  const projects = await getLocalizedProjects(locale);

  return projects
    .filter(p => p.data.pageContent && p.data.slug)
    .map(p => ({
      params: { slug: p.data.slug },
      props: { project: p.data, locale },
    }));
}

const { project, locale } = Astro.props;
const pageContent = project.pageContent as Parameters<typeof ProjectDetail>[0]['pageContent'];
const t = getTranslations(locale);
---

<BaseLayout
  title={project.title}
  description={t.meta.description}
  locale={locale}
>
  <div class="min-h-screen flex flex-col bg-linear-180 from-(--navy) to-(--dark-navy) text-slate-200 scroll-smooth">
    <Header locale={locale} />
    <ProjectDetail title={project.title} pageContent={pageContent} />
    <Footer locale={locale} />
  </div>
</BaseLayout>
